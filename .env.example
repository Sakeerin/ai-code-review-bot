# ─── Cloudflare Workers (webhook) ─────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=
GITLAB_TOKEN=
GITLAB_API_URL=https://gitlab.com/api/v4
ANTHROPIC_API_KEY=
TRIGGER_SECRET_KEY=
DATABASE_URL=                   # Supabase connection string (postgresql://...)

# ─── Next.js Dashboard ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_METER_ID=               # Stripe Meter ID (used when attaching meter to a price)
STRIPE_METER_EVENT_NAME=       # e.g. pr_review (must match the meter's event_name)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_TEAM_PRICE_ID=              # Team monthly ($19/mo)
STRIPE_BUSINESS_PRICE_ID=          # Business monthly ($49/mo)
STRIPE_TEAM_ANNUAL_PRICE_ID=       # Team annual ($180/yr — $15/mo equivalent)
STRIPE_BUSINESS_ANNUAL_PRICE_ID=   # Business annual ($468/yr — $39/mo equivalent)
STRIPE_OVERAGE_PRICE_ID=           # Usage-based overage price ($0.05/PR, attach to Billing Meter)
GITHUB_APP_SLUG=ai-review-bot      # Slug from your GitHub App URL
SUPPORT_EMAIL=                     # Sales/support email for enterprise lead notifications
SLACK_WEBHOOK_URL=             # Incoming webhook URL for review completion notifications

# ─── Observability ───────────────────────────────────────────
AXIOM_TOKEN=
SENTRY_DSN=

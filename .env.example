# ─── Cloudflare Workers (webhook) ─────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=
GITLAB_TOKEN=
GITLAB_API_URL=https://gitlab.com/api/v4
ANTHROPIC_API_KEY=
TRIGGER_SECRET_KEY=
DATABASE_URL=                   # Supabase connection string (postgresql://...)

# ─── Next.js Dashboard ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_METER_ID=               # Stripe Meter ID (used when attaching meter to a price)
STRIPE_METER_EVENT_NAME=       # e.g. pr_review (must match the meter's event_name)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_TEAM_PRICE_ID=          # Stripe Price ID for Team plan ($19/mo recurring)
STRIPE_BUSINESS_PRICE_ID=      # Stripe Price ID for Business plan ($49/mo recurring)
GITHUB_APP_SLUG=ai-review-bot  # The slug from your GitHub App URL
SLACK_WEBHOOK_URL=             # Incoming webhook URL for review completion notifications

# ─── Observability ───────────────────────────────────────────
AXIOM_TOKEN=
SENTRY_DSN=

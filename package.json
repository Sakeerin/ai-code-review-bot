{
  "name": "ai-review-bot",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "bun run --filter @repo/db generate",
    "db:migrate": "bun run --filter @repo/db migrate",
    "db:push": "bun run --filter @repo/db push",
    "db:studio": "bun run --filter @repo/db studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.8.0",
    "prettier": "^3.5.0",
    "@types/bun": "^1.3.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.0"
}
